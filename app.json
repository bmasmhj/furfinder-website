{
  "expo": {
    "name": "The Fur Finder",
    "slug": "pet-reunite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/store/app-icon-512.png",
    "scheme": "thefurfinder",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/store/app-icon-512.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAFA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.petreunite.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "The Fur Finder needs access to your camera to take photos of lost or found pets.",
        "NSPhotoLibraryUsageDescription": "The Fur Finder needs access to your photo library to upload pet photos for reports and profiles.",
        "NSLocationWhenInUseUsageDescription": "The Fur Finder needs your location to show nearby lost and found pets and to accurately pin reports on the map.",
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "package": "com.petreunite.app",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#FF6B4A",
        "foregroundImage": "./assets/store/app-icon-512.png"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/store/app-icon-512.png",
          "color": "#FF6B4A",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "21469ea0-393c-4eb2-b173-11f9621e8f04"
      }
    },
    "owner": "jessicabhullar"
  }
}
